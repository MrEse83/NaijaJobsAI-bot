    "@prisma/client": "^7.4.2",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.18.0",
    "anthropic": "^0.0.0",
    "axios": "^1.9.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "node-cron": "^3.0.3",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
