{
  "name": "naijajobs-bot",
  "version": "1.0.0",
  "main": "src/index.ts",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "start": "ts-node src/index.ts",
    "scrape": "ts-node src/scraper/index.ts",
